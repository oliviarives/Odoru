@startuml UC07_PlanifierCours
title UC07 – PlanifierCours

actor "Enseignant" as ENS
participant "CallMe App" as App
participant ":CoursController" as C
participant ":CoursService" as S
participant ":MembreService" as MS
participant ":CoursRepository" as R
database "Base de données" as DB

ENS -> App : Saisit (titre, niveauCible, jour,\nheureDebut, lieu, duree, dateDebut)
App -> C : POST /api/cours\n{body: CoursDTO}\nHeader: Authorization: Bearer <token>
C -> C : @PreAuthorize hasRole('ENSEIGNANT')\nenseignant = @AuthenticationPrincipal\n(extrait du JWT, PAS du body)
C -> C : verifierToken(token)
C -> C : verifierRole(ENSEIGNANT)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> ENS : "Accès refusé"
else Rôle autorisé
  C -> S : planifierCours(CoursDTO, enseignantId)

  == Règle métier 1 : date > J+7 ==
  S -> S : verifierDelai(dateDebut)\n' dateDebut >= dateSaisie + 7 jours
  alt Date trop proche (< J+7)
    S --> C : throws DateTropProcheException
    C --> App : 400 Bad Request
    App --> ENS : "Un cours doit être planifié\nau moins 7 jours à l'avance"
  else Délai respecté

    == Règle métier 2 : enseignant apte au niveau ==
    S -> MS : getMembreById(enseignantId)
    MS --> S : Membre (enseignant)
    S -> S : verifierAptitude(enseignant.niveauExpertise,\nniveauCible)\n' niveauExpertise >= niveauCible
    alt Niveau insuffisant
      S --> C : throws NiveauInsuffisantException
      C --> App : 403 Forbidden
      App --> ENS : "Niveau d'expertise insuffisant\npour ce niveau de cours"
    else Enseignant apte

      == Règle métier 3 : créneau libre ==
      S -> R : existsByCreneauAndLieu(jour, heureDebut, lieu)
      R -> DB : SELECT COUNT(*) ...
      DB --> R : résultat
      R --> S : boolean
      alt Créneau occupé
        S --> C : throws CreneauOccupeException
        C --> App : 409 Conflict
        App --> ENS : "Créneau déjà occupé"
      else Créneau libre
        S -> R : save(Cours)
        R -> DB : INSERT INTO evenement + cours
        DB --> R : Cours persisté
        R --> S : Cours
        note right of S : Les élèves de niveau X sont\nde facto inscrits (jointure dynamique\nsur niveauExpertise = niveauCible)
        S --> C : CoursDTO
        C --> App : 201 Created
        App --> ENS : Cours planifié avec succès
      end
    end
  end
end

@enduml

