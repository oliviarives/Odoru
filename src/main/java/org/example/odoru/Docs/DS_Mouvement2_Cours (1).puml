@startuml UC08_ConsulterPlagesCoursNiveau
title UC08 – ConsulterPlagesCoursNiveau (Élève)

actor "Élève" as EL
participant "CallMe App" as App
participant ":CoursController" as C
participant ":CoursService" as S
participant ":CoursRepository" as R
database "Base de données" as DB

EL -> App : Consulte les cours de son niveau
App -> C : GET /api/cours?niveauCible={niveau}\nHeader: Authorization: Bearer <token>
C -> C : verifierToken(token)

alt Token invalide
  C --> App : 401 Unauthorized
  App --> EL : "Session expirée"
else Token valide
  C -> C : validerNiveau(niveauCible)

  alt Niveau invalide
    C --> App : 400 Bad Request
    App --> EL : "Niveau invalide"
  else Niveau valide
    C -> S : getCoursParNiveau(niveauCible)
    S -> R : findByNiveauCible(niveauCible)
    R -> DB : SELECT * FROM cours\nWHERE niveauCible=? AND dateDebut >= now()
    DB --> R : Liste de cours
    R --> S : List<Cours>
    S --> C : List<CoursDTO>
    C --> App : 200 OK [CoursDTO, ...]
    App --> EL : Affiche les créneaux de cours
  end
end

@enduml

' ─────────────────────────────────────────────

@startuml UC09_ConsulterPlageCours_Enseignant
title UC09 – ConsulterPlageCours (Enseignant)

actor "Enseignant" as ENS
participant "CallMe App" as App
participant ":CoursController" as C
participant ":CoursService" as S
participant ":CoursRepository" as R
database "Base de données" as DB

ENS -> App : Consulte les cours qu'il donne
App -> C : GET /api/cours?enseignantId={id}\nHeader: Authorization: Bearer <token>
C -> C : verifierToken(token)

alt Token invalide
  C --> App : 401 Unauthorized
  App --> ENS : "Session expirée"
else Token valide
  note right of C : enseignantId est extrait du token\n(l'enseignant ne voit que SES cours)
  C -> S : getCoursParEnseignant(enseignantId)
  S -> R : findByEnseignantId(enseignantId)
  R -> DB : SELECT * FROM cours WHERE enseignant_id=?
  DB --> R : Liste de cours
  R --> S : List<Cours>
  S --> C : List<CoursDTO>
  C --> App : 200 OK [CoursDTO, ...]
  App --> ENS : Affiche ses créneaux de cours
end

@enduml
