@startuml UC15_BadgerPresence
title UC15 – BadgerPrésence (Boîtier)

actor "Boîtier physique" as BOX
participant ":BadgeController" as C
participant ":PresenceService" as S
participant ":BadgeRepository" as BR
participant ":CoursRepository" as CR
participant ":PresenceRepository" as PR
database "Base de données" as DB

note over BOX : L'élève badge sur le boîtier.\nLe boîtier émet un appel REST (simulé).

BOX -> C : POST /api/badges/badger\n{body: {numeroBadge}}
C -> S : enregistrerPresence(numeroBadge)

== Identifier le porteur du badge ==
S -> BR : findByNumeroBadge(numeroBadge)
BR -> DB : SELECT * FROM badge WHERE numero=?
DB --> BR : Badge ou null
BR --> S : Optional<Badge>
alt Badge inconnu
  S --> C : throws BadgeNotFoundException
  C --> BOX : 404 Not Found
else Badge reconnu

  == Identifier le cours courant ==
  S -> CR : findCoursCourant(badge.membre.niveauExpertise, now())
  CR -> DB : SELECT * FROM cours\nWHERE niveauCible=? AND créneau en cours
  DB --> CR : Cours ou null
  CR --> S : Optional<Cours>
  alt Aucun cours en cours
    S --> C : throws PasDeCoursCourantException
    C --> BOX : 409 Conflict
  else Cours en cours trouvé

    == Vérifier non-doublon ==
    S -> PR : existsByMembreAndCours(membreId, coursId)
    PR -> DB : SELECT COUNT(*) ...
    DB --> PR : résultat
    PR --> S : boolean
    alt Présence déjà enregistrée
      S --> C : throws DejaPresException
      C --> BOX : 409 Conflict
    else Première présence
      S -> PR : save(Presence)
      PR -> DB : INSERT INTO presence\n(membre_id, cours_id, dateHeure)
      DB --> PR : Presence persistée
      PR --> S : Presence
      S --> C : {membreId, coursId, dateHeure}
      C --> BOX : 200 OK
    end
  end
end

@enduml

