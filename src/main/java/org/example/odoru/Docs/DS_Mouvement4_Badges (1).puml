@startuml UC14_DissocierBadge
title UC14 – DissocierBadge

actor "Secrétaire" as SEC
participant "CallMe App" as App
participant ":MembreController" as C
participant ":BadgeService" as S
participant ":MembreRepository" as MR
participant ":BadgeRepository" as BR
database "Base de données" as DB

SEC -> App : Dissocie le badge d'un membre
App -> C : DELETE /api/membres/{id}/badge
C -> C : verifierToken(token)
C -> C : verifierRole(SECRETAIRE)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> SEC : "Seul le secrétaire peut dissocier un badge"
else Rôle autorisé
  C -> S : dissocierBadge(membreId)

  S -> MR : findById(membreId)
  MR -> DB : SELECT * FROM membre WHERE id=?
  DB --> MR : Membre ou null
  MR --> S : Optional<Membre>
  alt Membre non trouvé
    S --> C : throws MembreNotFoundException
    C --> App : 404 Not Found
    App --> SEC : "Membre introuvable"
  else Membre trouvé

    S -> S : verifierBadgeAssocie(membre)
    alt Aucun badge associé
      S --> C : throws AucunBadgeAssocieException
      C --> App : 404 Not Found
      App --> SEC : "Aucun badge associé à ce membre"
    else Badge présent
      S -> BR : dissocier(badge)
      BR -> DB : UPDATE badge SET membre_id=NULL
      note right of BR : Le badge n'est PAS supprimé\n(agrégation 0..1)
      DB --> BR : OK
      BR --> S : OK
      S --> C : {membreId, message: "Badge dissocié"}
      C --> App : 200 OK
      App --> SEC : Badge dissocié avec succès
    end
  end
end

@enduml

