@startuml UC16_HistoriqueCoursSuivi
title UC16 – HistoriqueCoursSuivi (Élève)

actor "Élève" as EL
participant "CallMe App" as App
participant ":MembreController" as C
participant ":PresenceService" as S
participant ":PresenceRepository" as PR
database "Base de données" as DB

EL -> App : Consulte les cours qu'il a suivis
App -> C : GET /api/membres/{id}/historique\nHeader: Authorization: Bearer <token>\nQuery (opt): dateDebut, dateFin
C -> C : verifierToken(token)
C -> C : verifierDroits(tokenId, id)\n' un élève ne voit que son propre historique

alt Accès non autorisé
  C --> App : 403 Forbidden
  App --> EL : "Accès refusé"
else Accès autorisé
  C -> S : getHistorique(id, dateDebut, dateFin)
  S -> PR : findByMembreId(id, dateDebut, dateFin)
  PR -> DB : SELECT p.*, c.titre, c.dateDebut\nFROM presence p JOIN cours c ...\nWHERE p.membre_id=?
  DB --> PR : Liste de présences
  PR --> S : List<Presence>

  alt Aucune présence
    S --> C : [] (liste vide)
    C --> App : 200 OK []
    App --> EL : "Aucun cours suivi"
  else Présences trouvées
    S --> C : List<HistoriqueDTO>
    C --> App : 200 OK [{coursId, titre, dateDebut, present}, ...]
    App --> EL : Affiche l'historique des cours suivis
  end
end

@enduml
