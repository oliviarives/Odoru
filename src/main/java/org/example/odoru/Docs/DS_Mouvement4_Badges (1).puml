@startuml UC13_AssocierBadge
title UC13 – AssocierBadge

actor "Secrétaire" as SEC
participant "CallMe App" as App
participant ":MembreController" as C
participant ":BadgeService" as S
participant ":MembreRepository" as MR
participant ":BadgeRepository" as BR
database "Base de données" as DB

SEC -> App : Associe un badge à un membre\n(saisit le numéro du badge)
App -> C : PUT /api/membres/{id}/badge\n{body: {numeroBadge}}
C -> C : verifierToken(token)
C -> C : verifierRole(SECRETAIRE)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> SEC : "Seul le secrétaire peut associer un badge"
else Rôle autorisé
  C -> S : associerBadge(membreId, numeroBadge)

  S -> MR : findById(membreId)
  MR -> DB : SELECT * FROM membre WHERE id=?
  DB --> MR : Membre ou null
  MR --> S : Optional<Membre>
  alt Membre non trouvé
    S --> C : throws MembreNotFoundException
    C --> App : 404 Not Found
    App --> SEC : "Membre introuvable"
  else Membre trouvé

    S -> BR : findByNumeroBadge(numeroBadge)
    BR -> DB : SELECT * FROM badge WHERE numero=?
    DB --> BR : Badge ou null
    BR --> S : Optional<Badge>
    alt Badge déjà associé à un autre membre
      S --> C : throws BadgeDejaAssocieException
      C --> App : 409 Conflict
      App --> SEC : "Badge déjà attribué"
    else Badge disponible
      S -> BR : save(Badge)
      BR -> DB : INSERT/UPDATE badge SET membre_id=?
      DB --> BR : Badge persisté
      BR --> S : Badge
      S --> C : {membreId, numeroBadge}
      C --> App : 200 OK
      App --> SEC : Badge associé avec succès
    end
  end
end

@enduml

