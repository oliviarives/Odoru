@startuml UC17c_StatsCompetitionsNiveau
title UC17c – VisualiserStats : Compétitions par niveau

actor "Président" as PRES
participant "CallMe App" as App
participant ":StatsController" as C
participant ":StatsService" as S
participant ":CompetitionRepository" as CR
database "Base de données" as DB

PRES -> App : Consulte le nombre de compétitions d'un niveau
App -> C : GET /api/stats/competitions?niveauCible={niveau}
C -> C : verifierToken(token)
C -> C : verifierRole(PRESIDENT)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> PRES : "Accès réservé au Président"
else Rôle autorisé
  C -> S : getStatsCompetitions(niveauCible)
  S -> CR : findByNiveauCible(niveauCible)
  CR -> DB : SELECT * FROM competition WHERE niveauCible=?
  DB --> CR : Liste de compétitions
  CR --> S : List<Competition>
  S -> S : compter(competitions)
  S --> C : {niveauCible, nbCompetitions,\ncompetitions: [{competitionId, titre, dateDebut}, ...]}
  C --> App : 200 OK
  App --> PRES : Affiche les compétitions du niveau
end

@enduml

