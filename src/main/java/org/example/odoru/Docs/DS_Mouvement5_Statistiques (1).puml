@startuml UC17b_StatsCoursEleve
title UC17b – VisualiserStats : Cours d'un élève (présences/absences)

actor "Président" as PRES
participant "CallMe App" as App
participant ":StatsController" as C
participant ":StatsService" as S
participant ":MembreRepository" as MR
participant ":PresenceRepository" as PR
database "Base de données" as DB

PRES -> App : Consulte les cours d'un élève donné
App -> C : GET /api/stats/membres/{id}/cours\nQuery (opt): dateDebut, dateFin
C -> C : verifierToken(token)
C -> C : verifierRole(PRESIDENT)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> PRES : "Accès réservé au Président"
else Rôle autorisé
  C -> S : getCoursEleve(id, dateDebut, dateFin)

  S -> MR : findById(id)
  MR -> DB : SELECT * FROM membre WHERE id=?
  DB --> MR : Membre ou null
  MR --> S : Optional<Membre>
  alt Élève non trouvé
    S --> C : throws MembreNotFoundException
    C --> App : 404 Not Found
    App --> PRES : "Élève introuvable"
  else Élève trouvé
    note right of S : Cours du niveau de l'élève (inscrits de facto)\ncroisés avec ses présences enregistrées
    S -> PR : findCoursAvecPresence(id, dateDebut, dateFin)
    PR -> DB : SELECT c.*, (présence existe?) AS present\nFROM cours c LEFT JOIN presence p ...
    DB --> PR : cours + indicateur présence
    PR --> S : List<CoursPresence>
    S --> C : [{coursId, titre, dateDebut, present: true/false}, ...]
    C --> App : 200 OK
    App --> PRES : Affiche cours avec présences/absences
  end
end

@enduml

