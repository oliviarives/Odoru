@startuml UC17d_StatsCompetitionsEleve
title UC17d – VisualiserStats : Compétitions d'un élève (résultats)

actor "Président" as PRES
participant "CallMe App" as App
participant ":StatsController" as C
participant ":StatsService" as S
participant ":MembreRepository" as MR
participant ":ResultatRepository" as RR
database "Base de données" as DB

PRES -> App : Consulte les compétitions d'un élève donné
App -> C : GET /api/stats/membres/{id}/competitions\nQuery (opt): dateDebut, dateFin
C -> C : verifierToken(token)
C -> C : verifierRole(PRESIDENT)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> PRES : "Accès réservé au Président"
else Rôle autorisé
  C -> S : getCompetitionsEleve(id, dateDebut, dateFin)

  S -> MR : findById(id)
  MR -> DB : SELECT * FROM membre WHERE id=?
  DB --> MR : Membre ou null
  MR --> S : Optional<Membre>
  alt Élève non trouvé
    S --> C : throws MembreNotFoundException
    C --> App : 404 Not Found
    App --> PRES : "Élève introuvable"
  else Élève trouvé
    S -> RR : findByMembreId(id, dateDebut, dateFin)
    RR -> DB : SELECT r.*, c.titre, c.dateDebut\nFROM resultat_competition r\nJOIN competition c ... WHERE r.membre_id=?
    DB --> RR : Liste de résultats
    RR --> S : List<ResultatCompetition>
    S --> C : [{competitionId, titre, dateDebut, note}, ...]
    C --> App : 200 OK
    App --> PRES : Affiche les compétitions et résultats de l'élève
  end
end

@enduml
