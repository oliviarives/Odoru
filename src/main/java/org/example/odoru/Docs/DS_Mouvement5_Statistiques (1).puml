@startuml UC17a_StatsCoursPresences
title UC17a – VisualiserStats : Cours + présences moyennes

actor "Président" as PRES
participant "CallMe App" as App
participant ":StatsController" as C
participant ":StatsService" as S
participant ":CoursRepository" as CR
participant ":PresenceRepository" as PR
database "Base de données" as DB

PRES -> App : Consulte les statistiques globales des cours
App -> C : GET /api/stats/cours\nHeader: Authorization: Bearer <token>
C -> C : verifierToken(token)
C -> C : verifierRole(PRESIDENT)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> PRES : "Accès réservé au Président"
else Rôle autorisé
  C -> S : getStatsCours()

  S -> CR : count()
  CR -> DB : SELECT COUNT(*) FROM cours
  DB --> CR : nbCours
  CR --> S : nbCours

  S -> PR : countPresencesParCours()
  PR -> DB : SELECT cours_id, COUNT(*)\nFROM presence GROUP BY cours_id
  DB --> PR : présences par cours
  PR --> S : Map<coursId, nbPresents>

  S -> S : calculerMoyenne(présences)
  S --> C : {nbCours, moyenneElevesPresents,\ncours: [{coursId, titre, nbPresents}, ...]}
  C --> App : 200 OK
  App --> PRES : Affiche les statistiques des cours
end

@enduml

