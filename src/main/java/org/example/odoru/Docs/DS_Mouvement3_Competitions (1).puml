@startuml UC12_VisualiserNotesCompetition
title UC12 – VisualiserNotesCompétition (Élève)

actor "Élève" as EL
participant "CallMe App" as App
participant ":CompetitionController" as C
participant ":CompetitionService" as S
participant ":ResultatRepository" as RR
database "Base de données" as DB

EL -> App : Consulte ses résultats de compétition
App -> C : GET /api/membres/{id}/competitions/resultats\nHeader: Authorization: Bearer <token>\nQuery (opt): dateDebut, dateFin
C -> C : verifierToken(token)
C -> C : verifierDroits(tokenId, id)\n' un élève ne voit que SES propres notes

alt Accès non autorisé
  C --> App : 403 Forbidden
  App --> EL : "Accès refusé"
else Accès autorisé
  C -> S : getResultatsParEleve(id, dateDebut, dateFin)
  S -> RR : findByMembreId(id, dateDebut, dateFin)
  RR -> DB : SELECT r.*, c.titre, c.dateDebut\nFROM resultat_competition r\nJOIN competition c ...\nWHERE r.membre_id=?
  DB --> RR : Liste de résultats
  RR --> S : List<ResultatCompetition>

  alt Aucun résultat
    S --> C : [] (liste vide)
    C --> App : 200 OK []
    App --> EL : "Aucun résultat de compétition"
  else Résultats trouvés
    S --> C : List<ResultatDTO>
    C --> App : 200 OK [{competitionId, titre, dateDebut, note}, ...]
    App --> EL : Affiche les notes de compétition
  end
end

@enduml
