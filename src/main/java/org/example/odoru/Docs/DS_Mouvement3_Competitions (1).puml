@startuml UC11_IndiquerResultatCompetition
title UC11 – IndiquerRésultatCompétition

actor "Enseignant" as ENS
participant "CallMe App" as App
participant ":CompetitionController" as C
participant ":CompetitionService" as S
participant ":CompetitionRepository" as CR
participant ":MembreRepository" as MR
participant ":ResultatRepository" as RR
database "Base de données" as DB

ENS -> App : Saisit la note d'un élève [0.0..10.0]
App -> C : PUT /api/competitions/{id}/resultats/{eleveId}\n{body: {note}}
C -> C : verifierToken(token)
C -> C : verifierRole(ENSEIGNANT)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> ENS : "Accès refusé"
else Rôle autorisé
  C -> S : indiquerResultat(competitionId, eleveId, note)

  == Validation de la note ==
  S -> S : validerNote(note)\n' 0.0 <= note <= 10.0, précision 0.1
  alt Note invalide
    S --> C : throws NoteInvalideException
    C --> App : 400 Bad Request
    App --> ENS : "Note invalide (0 à 10, au 1/10e)"
  else Note valide

    S -> CR : findById(competitionId)
    CR -> DB : SELECT * FROM competition WHERE id=?
    DB --> CR : Competition ou null
    CR --> S : Optional<Competition>
    alt Compétition non trouvée
      S --> C : throws CompetitionNotFoundException
      C --> App : 404 Not Found
      App --> ENS : "Compétition introuvable"
    else Compétition trouvée

      S -> MR : findById(eleveId)
      MR -> DB : SELECT * FROM membre WHERE id=?
      DB --> MR : Membre ou null
      MR --> S : Optional<Membre>
      alt Élève non trouvé
        S --> C : throws MembreNotFoundException
        C --> App : 404 Not Found
        App --> ENS : "Élève introuvable"
      else Élève trouvé
        S -> RR : save(ResultatCompetition)
        RR -> DB : INSERT/UPDATE resultat_competition
        DB --> RR : Resultat persisté
        RR --> S : ResultatCompetition
        S --> C : {competitionId, eleveId, note}
        C --> App : 200 OK
        App --> ENS : Résultat enregistré
      end
    end
  end
end

@enduml

