@startuml UC10_PlanifierCompetition
title UC10 – PlanifierCompétition

actor "Enseignant" as ENS
participant "CallMe App" as App
participant ":CompetitionController" as C
participant ":CompetitionService" as S
participant ":MembreService" as MS
participant ":CompetitionRepository" as R
database "Base de données" as DB

ENS -> App : Saisit (titre, niveauCible, jour,\nheureDebut, lieu, duree, dateDebut)
App -> C : POST /api/competitions\n{body: CompetitionDTO}\nHeader: Authorization: Bearer <token>
C -> C : @PreAuthorize hasRole('ENSEIGNANT')\nenseignant = @AuthenticationPrincipal\n(extrait du JWT, PAS du body)
C -> C : verifierToken(token)
C -> C : verifierRole(ENSEIGNANT)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> ENS : "Accès refusé"
else Rôle autorisé
  C -> S : planifierCompetition(CompetitionDTO, enseignantId)

  == Règle métier 1 : date > J+7 ==
  S -> S : verifierDelai(dateDebut)
  alt Date trop proche (< J+7)
    S --> C : throws DateTropProcheException
    C --> App : 400 Bad Request
    App --> ENS : "Une compétition doit être planifiée\nau moins 7 jours à l'avance"
  else Délai respecté

    == Règle métier 2 : enseignant apte au niveau ==
    S -> MS : getMembreById(enseignantId)
    MS --> S : Membre (enseignant)
    S -> S : verifierAptitude(enseignant.niveauExpertise,\nniveauCible)
    alt Niveau insuffisant
      S --> C : throws NiveauInsuffisantException
      C --> App : 403 Forbidden
      App --> ENS : "Niveau d'expertise insuffisant"
    else Enseignant apte
      S -> R : save(Competition)
      R -> DB : INSERT INTO evenement + competition
      DB --> R : Competition persistée
      R --> S : Competition
      S --> C : CompetitionDTO
      C --> App : 201 Created
      App --> ENS : Compétition planifiée avec succès
    end
  end
end

@enduml

