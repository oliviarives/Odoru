@startuml UC00_InscriptionExterne
title UC00 – Inscription externe (register)

actor "Personne externe" as U
participant "CallMe App" as App
participant ":RestAuth" as C
participant ":ServiceAuth" as S
participant ":MembreRepository" as R
database "Base de données" as DB

note over C : Endpoint PUBLIC (@PermitAll)\n/api/auth/register

U -> App : Remplit le formulaire d'inscription
App -> C : POST /api/auth/register\n{body: InscriptionImport}
C -> S : inscrire(InscriptionImport)

== Validation du niveau ==
S -> S : validerNiveau(niveauExpertise)\n' entre 1 et 5
alt Niveau hors bornes
  S --> C : throws NiveauInvalide
  C --> App : 400 Bad Request
  App --> U : "Niveau invalide (1 à 5)"
else Niveau valide

  == Unicité username ==
  S -> R : findByUsername(username)
  R -> DB : SELECT * WHERE username=?
  DB --> R : Optional<Membre>
  R --> S : Optional<Membre>
  alt Username pris
    S --> C : throws UsernameDejaUtilise
    C --> App : 409 Conflict
    App --> U : "Nom d'utilisateur déjà utilisé"
  else Username libre

    == Unicité email ==
    S -> R : findByEmail(email)
    R -> DB : SELECT * WHERE email=?
    DB --> R : Optional<Membre>
    R --> S : Optional<Membre>
    alt Email pris
      S --> C : throws EmailDejaUtilise
      C --> App : 409 Conflict
      App --> U : "Email déjà utilisé"
    else Email libre
      S -> S : hashPassword(password)
      note right of S : role = ELEVE (par défaut)\netatInscription = EN_ATTENTE\n(validation ultérieure par le secrétaire)\ndateInscription = now()
      S -> R : save(Membre)
      R -> DB : INSERT INTO membre
      DB --> R : Membre persisté
      R --> S : Membre
      S --> C : MembreExport (sans password)
      C --> App : 201 Created
      App --> U : "Compte créé – en attente de validation"
    end
  end
end

@enduml
