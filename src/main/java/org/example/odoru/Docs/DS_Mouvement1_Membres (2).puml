@startuml UC06_MAJNiveauExpertise
title UC06 – MAJNiveauExpertise (= RenseigNiveauExpertise)

actor "Secrétaire" as SEC
participant "CallMe App" as App
participant ":MembreController" as C
participant ":MembreService" as S
participant ":MembreRepository" as R
database "Base de données" as DB

SEC -> App : Saisit le nouveau niveau [1..5]
App -> C : PUT /api/membres/{id}/niveau\n{body: {niveauExpertise}}
C -> C : verifierToken(token)
C -> C : verifierRole(SECRETAIRE)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> SEC : "Accès refusé"
else Rôle autorisé
  C -> S : majNiveau(id, niveauExpertise)
  S -> S : validerNiveau(niveauExpertise)\n' doit être entre 1 et 5

  alt Niveau hors bornes
    S --> C : throws NiveauInvalideException
    C --> App : 400 Bad Request
    App --> SEC : "Niveau invalide (1 à 5)"
  else Niveau valide
    S -> R : findById(id)
    R -> DB : SELECT * FROM membre WHERE id=?
    DB --> R : Membre ou null
    R --> S : Optional<Membre>

    alt Membre non trouvé
      S --> C : throws MembreNotFoundException
      C --> App : 404 Not Found
      App --> SEC : "Membre introuvable"
    else Membre trouvé
      S -> R : save(membre)
      R -> DB : UPDATE membre SET niveauExpertise=? WHERE id=?
      DB --> R : OK
      R --> S : Membre mis à jour
      S --> C : {membreId, niveauExpertise}
      C --> App : 200 OK
      App --> SEC : Niveau mis à jour
    end
  end
end

@enduml

