@startuml UC02_ConnecterCompte
title UC02 – ConnecterCompte

actor "Utilisateur" as U
participant "CallMe App" as App
participant ":AuthController" as C
participant ":AuthService" as S
participant ":MembreRepository" as R
database "Base de données" as DB

U -> App : Saisit (username, password)
App -> C : POST /api/auth/login\n{body: LoginDTO}
C -> S : authentifier(username, password)

S -> R : findByUsername(username)
R -> DB : SELECT * FROM membre WHERE username=?
DB --> R : Membre ou null
R --> S : Optional<Membre>

alt Membre non trouvé
  S --> C : throws BadCredentialsException
  C --> App : 401 Unauthorized
  App --> U : "Identifiants incorrects"
else Membre trouvé
  S -> S : verifierPassword(password, hash)

  alt Mot de passe incorrect
    S --> C : throws BadCredentialsException
    C --> App : 401 Unauthorized
    App --> U : "Identifiants incorrects"
  else Mot de passe correct
    S -> S : genererJWT(membre)
    S --> C : {token, role, membreId}
    C --> App : 200 OK
    App -> App : Stocker le token (localStorage)
    App --> U : Connecté – redirige selon le rôle
  end
end

@enduml

' ─────────────────────────────────────────────

@startuml UC03_ConsulterCompte
title UC03 – ConsulterCompte

actor "Membre connecté" as U
participant "CallMe App" as App
participant ":MembreController" as C
participant ":MembreService" as S
participant ":MembreRepository" as R
database "Base de données" as DB

U -> App : Consulte son profil
App -> C : GET /api/membres/{id}\nHeader: Authorization: Bearer <token>
C -> C : verifierToken(token)

alt Token invalide / expiré
  C --> App : 401 Unauthorized
  App --> U : "Session expirée"
else Token valide
  C -> C : verifierDroits(tokenId, id)\n' un membre ne peut voir que son propre profil\n' sauf Secrétaire et Président

  alt Accès non autorisé
    C --> App : 403 Forbidden
    App --> U : "Accès refusé"
  else Accès autorisé
    C -> S : getMembreById(id)
    S -> R : findById(id)
    R -> DB : SELECT * FROM membre WHERE id=?
    DB --> R : Membre ou null
    R --> S : Optional<Membre>

    alt Membre non trouvé
      S --> C : throws MembreNotFoundException
      C --> App : 404 Not Found
      App --> U : "Membre introuvable"
    else Membre trouvé
      S --> C : MembreDTO
      C --> App : 200 OK {MembreDTO}
      App --> U : Affiche le profil
    end
  end
end

@enduml

