@startuml UC04_VerifierEtatInscription
title UC04 – VérifierÉtatInscription

actor "Secrétaire" as SEC
participant "CallMe App" as App
participant ":MembreController" as C
participant ":MembreService" as S
participant ":MembreRepository" as R
database "Base de données" as DB

SEC -> App : Recherche un membre
App -> C : GET /api/membres/{id}/inscription\nHeader: Authorization: Bearer <token>
C -> C : verifierToken(token)
C -> C : verifierRole(SECRETAIRE | PRESIDENT)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> SEC : "Accès refusé"
else Rôle autorisé
  C -> S : getEtatInscription(id)
  S -> R : findById(id)
  R -> DB : SELECT * FROM membre WHERE id=?
  DB --> R : Membre ou null
  R --> S : Optional<Membre>

  alt Membre non trouvé
    S --> C : throws MembreNotFoundException
    C --> App : 404 Not Found
    App --> SEC : "Membre introuvable"
  else Membre trouvé
    S --> C : {membreId, etatInscription, dateInscription}
    C --> App : 200 OK
    App --> SEC : Affiche l'état de l'inscription
  end
end

@enduml

' ─────────────────────────────────────────────

@startuml UC05_MAJEtatInscription
title UC05 – MAJÉtatInscription

actor "Secrétaire" as SEC
participant "CallMe App" as App
participant ":MembreController" as C
participant ":MembreService" as S
participant ":MembreRepository" as R
database "Base de données" as DB

SEC -> App : Modifie l'état d'inscription d'un membre
App -> C : PUT /api/membres/{id}/inscription\n{body: {etatInscription}}
C -> C : verifierToken(token)
C -> C : verifierRole(SECRETAIRE)

alt Rôle insuffisant
  C --> App : 403 Forbidden
  App --> SEC : "Accès refusé"
else Rôle autorisé
  C -> S : majEtatInscription(id, etatInscription)
  S -> S : validerEtat(etatInscription)\n' ACTIVE | SUSPENDUE | EXPIREE

  alt État invalide
    S --> C : throws EtatInvalideException
    C --> App : 400 Bad Request
    App --> SEC : "État invalide"
  else État valide
    S -> R : findById(id)
    R -> DB : SELECT * FROM membre WHERE id=?
    DB --> R : Membre ou null
    R --> S : Optional<Membre>

    alt Membre non trouvé
      S --> C : throws MembreNotFoundException
      C --> App : 404 Not Found
      App --> SEC : "Membre introuvable"
    else Membre trouvé
      S -> R : save(membre)
      R -> DB : UPDATE membre SET etat=? WHERE id=?
      DB --> R : OK
      R --> S : Membre mis à jour
      S --> C : {membreId, etatInscription}
      C --> App : 200 OK
      App --> SEC : Inscription mise à jour
    end
  end
end

@enduml

