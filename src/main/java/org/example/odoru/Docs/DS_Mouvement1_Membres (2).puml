@startuml UC01_CreerCompte
title UC01 – CréerCompte

actor "Utilisateur" as U
participant "CallMe App" as App
participant ":MembreController" as C
participant ":MembreService" as S
participant ":MembreRepository" as R
database "Base de données" as DB

U -> App : Saisit (nom, prenom, email,\nusername, password, ville, pays)
App -> C : POST /api/membres\n{body: MembreDTO}
C -> S : creerCompte(MembreDTO)

S -> R : existsByUsername(username)
R -> DB : SELECT COUNT(*) WHERE username=?
DB --> R : résultat
R --> S : boolean

alt username déjà existant
  S --> C : throws UsernameAlreadyExistsException
  C --> App : 409 Conflict
  App --> U : "Nom d'utilisateur déjà utilisé"
else username disponible
  S -> R : existsByEmail(email)
  R -> DB : SELECT COUNT(*) WHERE email=?
  DB --> R : résultat
  R --> S : boolean

  alt email déjà existant
    S --> C : throws EmailAlreadyExistsException
    C --> App : 409 Conflict
    App --> U : "Email déjà utilisé"
  else email disponible
    S -> S : hashPassword(password)
    S -> R : save(Membre)
    R -> DB : INSERT INTO membre
    DB --> R : Membre persisté
    R --> S : Membre
    S --> C : MembreDTO (id, username, email)
    C --> App : 201 Created
    App --> U : Compte créé avec succès
  end
end

@enduml

